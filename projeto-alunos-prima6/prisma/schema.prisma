// Gerador do Prisma Client
generator client {
  provider = "prisma-client-js"
}

// Fonte de dados (MariaDB)
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Modelo da tabela Cliente
model Cliente {
  id            Int      @id @default(autoincrement()) // Chave primária
  email         String   @unique                       // Email único
  nome          String                                 // Nome do cliente
  produto       String                                 // Produto escolhido 
  cpf           String   @unique                       // CPF do cliente
  telefone      String   @unique                       // Telefone do cliente
  rua           String                                 // Rua do cliente
  cep           String                                 // CEP do cliente
  numeroCasa    Int                                    // Número da casa do cliente
  criadoEm      DateTime @default(now())               // Data de criação
  atualizadoEm  DateTime @updatedAt                    // Atualização automática

  @@map("confeitaria") // Nome real da tabela no banco
}
